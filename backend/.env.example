# Backend Environment Variables

# Server
PORT=5173
JWT_SECRET=your-very-secret-key-change-me

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
